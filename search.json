---
layout: null
---
{% assign all_docs = site.posts | concat: site.note | sort: "date" | reverse %}
[{% for doc in all_docs %}
{"title":{{ doc.title | jsonify }},"url":{{ doc.url | jsonify }},"date":{{ doc.date | date: "%Y-%m-%d" | jsonify }},"date_ja":{{ doc.date | date: "%Y年%m月%d日" | jsonify }},"tags":{{ doc.tags | join: " " | jsonify }},"content":{{ doc.content | strip_html | normalize_whitespace | truncate: 4000 | jsonify }},"collection":{% if doc.collection == "note" %}"note"{% else %}"blog"{% endif %}}{% unless forloop.last %},{% endunless %}
{% endfor %}]
